{
  "name": "mega-bridge",
  "version": "2.0.0",
  "description": "HTTP proxy for downloading files from shared MEGA folders",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "DOWNLOAD_DIR=./data/files DB_PATH=./data/mega-bridge.db npx tsx --watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "express": "^5.2.1",
    "megajs": "^1.3.0",
    "picomatch": "^4.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/picomatch": "^4.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
